# Copy to .env and fill only what you need.
NODE_ENV=production

# Optional Telegram notifications for future runners.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Read-only API bases for future pair-cost scanner.
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
CLOB_API_BASE_URL=https://clob.polymarket.com
PAIR_COST_LOG_DIR=logs

# Trading mode. Defaults to paper. small_live also requires ENABLE_LIVE_TRADING=true.
TRADING_MODE=paper
ENABLE_LIVE_TRADING=false

# Optional wallet/key material for generating CLOB API credentials.
# Required only for small_live.
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...

# CLOB API credentials generated by src/scripts/generate-clob-api-key.ts.
# Required only for small_live.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
