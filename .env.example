# Copy to .env and fill in real values
NODE_ENV=production

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

MODE=paper
# Must be true before start:live can submit real orders in MODE=small_live
LIVE_TRADING_ENABLED=false

MIN_LIQUIDITY_USD=5000
MIN_VOLUME_24H_USD=1000
MAX_SPREAD_CENTS=5
# Keep 3 by default. Use 1 only after shadow candidate statistics justify tight-book live testing.
MIN_SPREAD_TICKS=3

# Small-live safety defaults. Increase only after shadow verification.
MAX_EXPOSURE_USD=10
MAX_DRAWDOWN_PCT=0.05

DAILY_REPORT_HOUR=20
DAILY_REPORT_MINUTE=0
TELEGRAM_REPORT_INTERVAL_HOURS=3

# Small-live safety default: max number of markets to trade simultaneously.
MAX_MARKETS=2

# Wallet private key for signing orders (64 hex chars after 0x)
PRIVATE_KEY=0x...

# CLOB API credentials (generate via scripts/generate-clob-api-key.ts)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Wallet address for position reconciliation (Data API)
# Your proxy wallet or EOA that holds positions on Polymarket
WALLET_ADDRESS=

# Small-live go/no-go gate inputs. Defaults block live startup unless explicitly set from paper-soak evidence.
SMALL_LIVE_RISK_STATUS=CRITICAL
SMALL_LIVE_RISK_REASONS=
SMALL_LIVE_REALIZED_PNL_EX_REBATES_USD=0
SMALL_LIVE_WORST_TOP_INVENTORY_EXIT_PNL_USD=
SMALL_LIVE_TESTS_PASSING=false
SMALL_LIVE_BUILD_PASSING=false

# Polymarket Relayer credentials (for gasless transactions)
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
