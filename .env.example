# Copy to .env and fill only what you need.
NODE_ENV=production

# Optional Telegram notifications for future runners.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Read-only API bases for pair-cost hedge-completion data runner.
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
CLOB_API_BASE_URL=https://clob.polymarket.com
PAIR_COST_LOG_DIR=logs
PAIR_COST_SCAN_INTERVAL_MS=30000
PAIR_COST_MAX_MARKETS=20

# Pair-cost strategy gate. Strategy can be enabled for data-only decisions while trading stays disabled.
PAIR_COST_ENABLED=false
PAIR_COST_TRADING_ENABLED=false
PAIR_COST_PROBE_ENABLED=false
PAIR_COST_ALLOW_PROBE_MODE=false

# Pair profitability.
PAIR_COST_MAX_PAIR_COST=0.985
PAIR_COST_TARGET_PAIR_COST=0.980
PAIR_COST_MIN_EDGE_PER_PAIR=0.015

# Exposure limits.
PAIR_COST_MAX_TOTAL_MARKET_EXPOSURE_USD=3
PAIR_COST_MAX_UNPAIRED_EXPOSURE_USD=1
PAIR_COST_MAX_SINGLE_ORDER_USD=1
PAIR_COST_MAX_SINGLE_ORDER_QTY=

# Timing and market quality.
PAIR_COST_MAX_UNPAIRED_HOLD_SECONDS=30
PAIR_COST_NO_NEW_PAIR_LAST_SECONDS=60
PAIR_COST_NO_NEW_PROBE_LAST_SECONDS=120
PAIR_COST_PARTIAL_FILL_TIMEOUT_MS=1500
PAIR_COST_CANCEL_REPLACE_COOLDOWN_MS=1000
PAIR_COST_MAX_SPREAD=0.04
PAIR_COST_MIN_DEPTH_USD=2
PAIR_COST_ORDERBOOK_STALE_MS=1500

# Execution flags are retained as fail-closed config only; this runner has no live order execution path.
PAIR_COST_ORDER_MODE=POST_ONLY
PAIR_COST_ALLOW_TAKER_FOR_HEDGE_COMPLETION=false

# Optional wallet/key material for CLOB key generation only. Not used by the data runner.
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
